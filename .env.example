# Environment Variables untuk HERO MARKET Backend

# Server Configuration
PORT=3000
NODE_ENV=production

# Session Secret (WAJIB di-set! Gunakan string random panjang yang aman)
# Generate: node -e "require('crypto').randomBytes(64).toString('hex')|cat"
SESSION_SECRET=GANTI_DENGAN_STRING_RANDOM_PANJANG_YANG_AMAN

# PakKasir API (Isi setelah mendaftar di pakasir.com)
PAKASIR_API_KEY=your_pakasir_api_key_here
PAKASIR_PROJECT=your_project_name_here
PAKASIR_MODE=production

# Admin Credentials (Default, akan di-hash otomatis)
ADMIN_USERNAME=heromarket
ADMIN_PASSWORD=sumberjo1903

# Contact Information
WHATSAPP_NUMBER=6281235690535
TELEGRAM_USERNAME=HEROO3STORE
SUPPORT_EMAIL=support@heromarket.com

# Site Configuration
SITE_NAME=HERO MARKET
MARQUEE_TEXT=LAYANAN GAME MOD MENU PREMIUM - PROSES CEPAT & AMAN

# ─── DATABASE: SUPABASE (Gantikan JSONBin) ───────────────────
# 1. Daftar gratis di https://supabase.com
# 2. Buat project baru (pilih region Singapore)
# 3. Buka Settings → API → copy URL dan anon key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
# Optional — untuk auto-create tabel jika belum ada
# Password database waktu bikin project di supabase.com
SUPABASE_DB_PASSWORD=your_database_password_here
