<%
const pageTitle = 'Register';
%>

<script>
if (typeof window !== 'undefined') {
  document.body.classList.add('auth-page');
  window.addEventListener('load', () => document.body.classList.add('auth-page'));
}
</script>

<div class="min-h-screen flex items-center justify-center px-4 py-20" style="background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <img src="https://z-cdn-media.chatglm.cn/files/87e4e759-3898-4bd9-93f3-42078956a794.png?auth_key=1878848442-1a65b6a56ce44d8188d26c370725de81-0-3e86df522848abe81fc556fd03a5fe98" alt="Logo" class="h-16 w-auto mx-auto mb-4 hm-logo-img">
            <h1 class="font-orbitron text-2xl font-bold tracking-wide mb-2" style="background:linear-gradient(135deg,#7b2cbf,#9d4edd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">HERO MARKET</h1>
            <p class="text-sm text-zinc-500">Buat akun baru</p>
        </div>

        <div class="bg-[#151520] rounded-xl border-2 border-purple-500/25 shadow-2xl overflow-hidden" style="box-shadow:0 0 30px rgba(157,78,221,.15);">
            <div class="p-6">
                <% if (error) { %>
                    <div class="mb-4 p-3 rounded-lg bg-red-500/10 border border-red-500/30 flex items-center gap-2">
                        <iconify-icon icon="mdi:alert-circle" class="text-red-400 text-lg"></iconify-icon>
                        <span class="text-xs text-red-400"><%= error %></span>
                    </div>
                <% } %>

                <form method="POST" action="/register" class="space-y-4" onsubmit="return validateRegister(event)">
                    <div>
                        <label class="block text-xs font-semibold text-zinc-400 mb-2">Username</label>
                        <div class="relative">
                            <iconify-icon icon="mdi:account" class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500"></iconify-icon>
                            <input type="text" name="username" required class="form-input pl-10" placeholder="Pilih username" pattern="[a-zA-Z0-9]+" minlength="4" maxlength="20" autofocus>
                        </div>
                        <p class="text-[10px] text-zinc-600 mt-1 ml-1">Minimal 4 karakter, hanya huruf dan angka</p>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-zinc-400 mb-2">No. WhatsApp</label>
                        <div class="relative">
                            <iconify-icon icon="mdi:whatsapp" class="absolute left-3 top-1/2 -translate-y-1/2 text-green-500"></iconify-icon>
                            <input type="tel" name="wa" required class="form-input pl-10" placeholder="08xxxxxxxxxx" pattern="[0-9]+" maxlength="15">
                        </div>
                        <p class="text-[10px] text-zinc-600 mt-1 ml-1">Format: 08xxx atau 628xxx</p>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-zinc-400 mb-2">Password</label>
                        <div class="relative">
                            <iconify-icon icon="mdi:lock" class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500"></iconify-icon>
                            <input type="password" name="password" id="reg-password" required class="form-input pl-10 pr-10" placeholder="Buat password" minlength="6" maxlength="30">
                            <button type="button" onclick="togglePass('reg-password','reg-eye')" class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300">
                                <iconify-icon icon="mdi:eye-outline" id="reg-eye" class="text-base"></iconify-icon>
                            </button>
                        </div>
                        <p class="text-[10px] text-zinc-600 mt-1 ml-1">Minimal 6 karakter</p>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-zinc-400 mb-2">Konfirmasi Password</label>
                        <div class="relative">
                            <iconify-icon icon="mdi:lock-check" class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500"></iconify-icon>
                            <input type="password" id="reg-confirm" name="confirmPassword" required class="form-input pl-10 pr-10" placeholder="Ulangi password">
                            <button type="button" onclick="togglePass('reg-confirm','reg-eye2')" class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300">
                                <iconify-icon icon="mdi:eye-outline" id="reg-eye2" class="text-base"></iconify-icon>
                            </button>
                        </div>
                        <p id="confirm-msg" class="text-[10px] mt-1 ml-1 hidden"></p>
                    </div>

                    <button type="submit" class="w-full py-2.5 rounded-lg text-white text-xs font-bold flex items-center justify-center gap-2 shadow-md shadow-emerald-500/20" style="background:linear-gradient(90deg,#10b981,#34d399);">
                        <iconify-icon icon="mdi:account-check" class="text-base"></iconify-icon>
                        <span>Daftar Sekarang</span>
                    </button>
                </form>

                <div class="mt-6 text-center">
                    <p class="text-xs text-zinc-500">
                        Sudah punya akun?
                        <a href="/login" class="text-indigo-400 hover:text-indigo-300 font-semibold">Masuk di sini</a>
                    </p>
                </div>

                <div class="mt-4 text-center">
                    <a href="/" class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors">
                        <iconify-icon icon="mdi:arrow-left" class="text-xs"></iconify-icon> Kembali ke Beranda
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function togglePass(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type = 'text';
        icon.setAttribute('icon', 'mdi:eye-off-outline');
    } else {
        input.type = 'password';
        icon.setAttribute('icon', 'mdi:eye-outline');
    }
}

document.getElementById('reg-confirm').addEventListener('input', function() {
    const pw = document.getElementById('reg-password').value;
    const msg = document.getElementById('confirm-msg');
    if (!this.value) { msg.className = 'text-[10px] mt-1 ml-1 hidden'; return; }
    if (this.value === pw) {
        msg.textContent = 'Password cocok';
        msg.className = 'text-[10px] mt-1 ml-1 text-emerald-400';
    } else {
        msg.textContent = 'Password tidak cocok';
        msg.className = 'text-[10px] mt-1 ml-1 text-red-400';
    }
});

function validateRegister(e) {
    const pw = document.getElementById('reg-password').value;
    const confirm = document.getElementById('reg-confirm').value;
    if (pw !== confirm) {
        e.preventDefault();
        document.getElementById('confirm-msg').textContent = 'Password tidak cocok';
        document.getElementById('confirm-msg').className = 'text-[10px] mt-1 ml-1 text-red-400';
        return false;
    }
    return true;
}
</script>
