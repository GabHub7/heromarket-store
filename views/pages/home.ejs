
<%
const pageTitle = 'Beranda';
%>

<!-- NAVBAR -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#08081a]/95 backdrop-blur-md border-b border-indigo-500/10 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center justify-between h-16">
            <a href="/" class="flex items-center gap-3 flex-shrink-0">
                <img src="https://z-cdn-media.chatglm.cn/files/87e4e759-3898-4bd9-93f3-42078956a794.png?auth_key=1878848442-1a65b6a56ce44d8188d26c370725de81-0-3e86df522848abe81fc556fd03a5fe98" alt="HM Logo" class="hm-logo-img h-12 w-auto object-contain">
                <span class="font-orbitron text-xl font-bold tracking-wide whitespace-nowrap neon-text"><%= settings.siteName || 'HERO MARKET' %></span>
            </a>
            <div class="hidden md:flex items-center gap-3">
                <a href="/invoice" class="nav-link text-xs font-medium text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5">
                    <iconify-icon icon="mdi:package-variant-closed" class="text-sm"></iconify-icon> Cek Pesanan
                </a>
                <div class="w-px h-4 bg-white/10"></div>
                <% if (isAdmin) { %>
                    <a href="/admin" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold transition-all hover:scale-105"
                       style="background:linear-gradient(135deg,rgba(234,88,12,.2),rgba(249,115,22,.12));border:1px solid rgba(234,88,12,.45);color:#fb923c;">
                        <iconify-icon icon="mdi:shield-crown" class="text-sm"></iconify-icon> Admin
                    </a>
                <% } else if (user && user.is_reseller) { %>
                    <a href="/reseller" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold"
                       style="background:rgba(234,179,8,.12);border:1px solid rgba(234,179,8,.3);color:#fbbf24;">
                        <iconify-icon icon="mdi:crown" class="text-sm"></iconify-icon> VIP
                    </a>
                <% } else if (resellerSettings && resellerSettings.enabled) { %>
                    <a href="/reseller" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold hover:scale-105 transition-all"
                       style="background:linear-gradient(135deg,rgba(234,179,8,.2),rgba(251,191,36,.12));border:1px solid rgba(234,179,8,.45);color:#fbbf24;">
                        <iconify-icon icon="mdi:crown" class="text-sm"></iconify-icon> Reseller
                    </a>
                <% } %>
                <% if (user) { %>
                    <div class="w-px h-4 bg-white/10"></div>
                    <a href="/logout" class="nav-link text-xs font-medium text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5">
                        <iconify-icon icon="mdi:logout" class="text-sm"></iconify-icon> Logout
                    </a>
                <% } else { %>
                    <div class="w-px h-4 bg-white/10"></div>
                    <a href="/login" class="nav-link text-xs font-medium text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5">
                        <iconify-icon icon="mdi:login" class="text-sm"></iconify-icon> Login
                    </a>
                <% } %>
            </div>
            <div class="flex items-center gap-2">
                <!-- CART ICON — selalu visible di header -->
                <button onclick="openCart()" class="relative w-10 h-10 rounded-xl flex items-center justify-center transition-all hover:scale-105 active:scale-95"
                    style="background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.25);">
                    <iconify-icon icon="mdi:cart-variant" class="text-indigo-400 text-lg"></iconify-icon>
                    <span id="cart-badge" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] rounded-full text-[9px] font-black text-white flex items-center justify-center px-1"
                        style="background:linear-gradient(135deg,#ef4444,#dc2626);border:2px solid #08081a;box-shadow:0 0 8px rgba(239,68,68,.5);"></span>
                </button>
                <% if (user) { %>
                    <button id="mobile-menu-btn" onclick="toggleMobile()" class="w-10 h-10 rounded-full overflow-hidden border border-white/10 bg-white/5 flex items-center justify-center transition-all hover:border-indigo-400 focus:outline-none">
                        <% if (user.photo) { %>
                            <img src="<%= user.photo %>" alt="Avatar <%= user.username %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <div class="w-full h-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-sm font-bold"><%= user.username.charAt(0).toUpperCase() %></div>
                        <% } %>
                    </button>
                <% } else { %>
                    <button id="mobile-menu-btn" onclick="toggleMobile()" class="md:hidden w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-zinc-500 hover:text-white transition-all">
                        <iconify-icon icon="mdi:menu" class="text-base" id="menu-icon"></iconify-icon>
                    </button>
                <% } %>
            </div>
        </div>
    </div>
    <div id="mobile-menu" class="md:hidden hidden border-t border-white/5 bg-[#08081a]">
        <div class="px-4 py-3 flex flex-col gap-0.5">
            <% if (user) { %>
            <!-- User info -->
            <div class="flex items-center gap-3 px-3 py-3 mb-1 rounded-xl" style="background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.15)">
                <div class="w-9 h-9 rounded-full flex-shrink-0 overflow-hidden border border-white/15">
                    <% if (user.photo) { %>
                        <img src="<%= user.photo %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <div class="w-full h-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-sm font-black"><%= user.username.charAt(0).toUpperCase() %></div>
                    <% } %>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-xs font-bold text-white truncate"><%= user.username %></div>
                    <% if (isAdmin) { %>
                        <div class="text-[10px] font-bold text-orange-400 flex items-center gap-1"><iconify-icon icon="mdi:shield-crown" class="text-[10px]"></iconify-icon> Administrator</div>
                    <% } else if (user.is_reseller) { %>
                        <div class="text-[10px] font-bold flex items-center gap-1" style="color:#fbbf24"><iconify-icon icon="mdi:crown" class="text-[10px]"></iconify-icon> Reseller VIP</div>
                    <% } else { %>
                        <div class="text-[10px] text-zinc-500">Member</div>
                    <% } %>
                </div>
            </div>
            <% } %>

            <a href="/" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
                <iconify-icon icon="mdi:home" class="text-sm"></iconify-icon> Beranda
            </a>
            <a href="/invoice" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
                <iconify-icon icon="mdi:clipboard-text-search" class="text-sm"></iconify-icon> Cek Pesanan
            </a>
            <a href="/leaderboard" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
                <iconify-icon icon="mdi:trophy" class="text-sm"></iconify-icon> Leaderboard
            </a>

            <% if (resellerSettings && resellerSettings.enabled) { %>
            <% if (user && user.is_reseller) { %>
            <a href="/reseller" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-bold transition-all"
               style="background:rgba(234,179,8,.1);border:1px solid rgba(234,179,8,.2);color:#fbbf24;">
                <iconify-icon icon="mdi:crown" class="text-sm"></iconify-icon> Status VIP Aktif
                <span class="ml-auto text-[9px] px-1.5 py-0.5 rounded" style="background:rgba(234,179,8,.2)">AKTIF</span>
            </a>
            <% } else { %>
            <a href="/reseller" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-bold transition-all"
               style="background:linear-gradient(135deg,rgba(234,179,8,.15),rgba(251,191,36,.08));border:1px solid rgba(234,179,8,.35);color:#fbbf24;">
                <iconify-icon icon="mdi:crown" class="text-sm"></iconify-icon> Masuk sebagai Reseller VIP
                <span class="ml-auto text-[9px] px-1.5 py-0.5 rounded" style="background:rgba(234,179,8,.2);color:#fbbf24">-<%= resellerSettings.discount %>%</span>
            </a>
            <% } %>
            <% } %>

            <div class="h-px bg-white/5 my-1"></div>
            <% if (user) { %>
                <a href="/logout" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
                    <iconify-icon icon="mdi:logout" class="text-sm"></iconify-icon> Logout
                </a>
            <% } else { %>
                <a href="/login" onclick="closeMobile()" class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-white hover:bg-white/5 transition-all">
                    <iconify-icon icon="mdi:account-circle" class="text-sm"></iconify-icon> Login / Daftar
                </a>
            <% } %>
        </div>
    </div>
</nav>

<!-- HERO BANNER CAROUSEL -->
<section id="home" class="pt-16">
    <!-- Banner full-width, tidak ada px agar menempel navbar -->
    <div id="carousel-wrap" class="relative overflow-hidden select-none"
         style="height:clamp(168px,35vw,260px);background:#07071a;border-bottom:1px solid rgba(99,102,241,.2);box-shadow:0 8px 40px rgba(99,102,241,.12);">

        <div id="carousel-track" class="flex h-full" style="transition:transform .52s cubic-bezier(.4,0,.2,1);will-change:transform;">

            <!-- DEFAULT SLIDE -->
            <div class="c-slide flex-shrink-0 relative" id="c-slide-default"
                 style="background:linear-gradient(135deg,#07071a 0%,#130929 55%,#07071a 100%);">
                <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 60% at 15% 50%,rgba(139,92,246,.22) 0%,transparent 70%);animation:bannerPulse 4s ease-in-out infinite;z-index:1;"></div>
                <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 50% 80% at 85% 50%,rgba(99,102,241,.12) 0%,transparent 70%);animation:bannerPulse 4s 2s ease-in-out infinite;z-index:1;"></div>
                <div class="absolute inset-0 pointer-events-none" style="background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.04) 3px,rgba(0,0,0,.04) 4px);z-index:2;"></div>
                <div class="relative z-10 h-full flex flex-col justify-center px-5 sm:px-10 max-w-2xl">
                    <div class="flex items-center gap-2 mb-2.5" style="animation:slideUpIn .45s ease-out both;">
                        <span class="flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-black" style="background:rgba(16,185,129,.18);border:1px solid rgba(16,185,129,.45);color:#34d399;">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block" style="animation:blink 1.4s infinite;"></span> LIVE
                        </span>
                        <span class="text-[9px] font-bold text-violet-400 tracking-[2px] uppercase">Premium Store</span>
                    </div>
                    <div class="font-orbitron font-black text-white leading-none mb-2"
                         style="font-size:clamp(22px,6vw,44px);text-shadow:0 0 32px rgba(139,92,246,.65);animation:slideUpIn .45s .08s ease-out both;">
                        <%= settings.siteName %>
                    </div>
                    <div class="text-violet-300 mb-4" style="font-size:clamp(10px,2vw,13px);line-height:1.5;animation:slideUpIn .45s .16s ease-out both;">
                        <%= settings.marqueeText || 'Layanan Game Mod Menu & Key Premium Terpercaya' %>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap" style="animation:slideUpIn .45s .24s ease-out both;">
                        <a href="#games" class="flex items-center gap-1.5 px-4 py-1.5 rounded-xl text-[11px] font-black text-white transition-all hover:scale-105 active:scale-95"
                           style="background:linear-gradient(135deg,#7c3aed,#6366f1);box-shadow:0 3px 14px rgba(99,102,241,.45);">
                            <iconify-icon icon="mdi:shopping" style="font-size:12px;"></iconify-icon> Lihat Produk
                        </a>
                        <a href="/invoice" class="flex items-center gap-1.5 px-4 py-1.5 rounded-xl text-[11px] font-bold transition-all hover:bg-white/10 active:scale-95"
                           style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:#94a3b8;">
                            <iconify-icon icon="mdi:package-variant-closed" style="font-size:12px;"></iconify-icon> Cek Pesanan
                        </a>
                    </div>
                </div>
            </div>
            <!-- admin slides injected by JS -->
        </div>

        <button id="carousel-prev" onclick="carouselMove(-1)"
            class="hidden absolute left-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full items-center justify-center z-20 transition-all hover:scale-110 active:scale-95"
            style="background:rgba(0,0,0,.6);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.15);color:#fff;">
            <iconify-icon icon="mdi:chevron-left" class="text-lg"></iconify-icon>
        </button>
        <button id="carousel-next" onclick="carouselMove(1)"
            class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full items-center justify-center z-20 transition-all hover:scale-110 active:scale-95"
            style="background:rgba(0,0,0,.6);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.15);color:#fff;">
            <iconify-icon icon="mdi:chevron-right" class="text-lg"></iconify-icon>
        </button>

        <!-- Dots selalu tampil minimal 1 -->
        <div id="carousel-dots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-1.5 z-20">
            <div class="c-dot active"></div>
        </div>
    </div>

    <!-- STATUS BAR -->
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center gap-2 py-2 overflow-x-auto" style="-ms-overflow-style:none;scrollbar-width:none;">
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl flex-shrink-0 text-[10px] font-bold" style="background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.22);color:#34d399;"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0" style="animation:blink 1.4s infinite;"></span> ONLINE 24 JAM</div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl flex-shrink-0 text-[10px] font-bold" style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);color:#4ade80;"><iconify-icon icon="mdi:android" style="font-size:12px"></iconify-icon> ANDROID</div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl flex-shrink-0 text-[10px] font-bold" style="background:rgba(148,163,184,.06);border:1px solid rgba(148,163,184,.18);color:#94a3b8;"><iconify-icon icon="mdi:apple" style="font-size:12px"></iconify-icon> iOS</div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl flex-shrink-0 text-[10px] font-bold" style="background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.22);color:#818cf8;"><iconify-icon icon="mdi:lightning-bolt" style="font-size:12px"></iconify-icon> PROSES INSTAN</div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl flex-shrink-0 text-[10px] font-bold" style="background:rgba(234,179,8,.08);border:1px solid rgba(234,179,8,.22);color:#fbbf24;"><iconify-icon icon="mdi:shield-check" style="font-size:12px"></iconify-icon> 100% AMAN</div>
        </div>
    </div>
</section>

<!-- STATS SECTION -->
<section class="relative py-6 sm:py-10">
    <div class="relative max-w-7xl mx-auto px-3 sm:px-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
            <div class="stat-card rounded-3xl p-5 sm:p-7 text-center transition-all duration-300 hover:scale-[1.03] hover:brightness-110"
                 style="background:#141428;border:1px solid rgba(255,255,255,.05);">
                <div class="font-orbitron font-black text-3xl sm:text-4xl mb-1.5" style="color:#fff;"><span id="stat-pelanggan">980</span><span style="color:#a78bfa;">+</span></div>
                <div class="text-white/40 text-[11px] sm:text-xs font-medium tracking-wide">Pelanggan</div>
            </div>
            <div class="stat-card rounded-3xl p-5 sm:p-7 text-center transition-all duration-300 hover:scale-[1.03] hover:brightness-110"
                 style="background:#141428;border:1px solid rgba(255,255,255,.05);">
                <div class="font-orbitron font-black text-3xl sm:text-4xl mb-1.5" style="color:#fff;">24<span style="color:#f97316;">/</span>7</div>
                <div class="text-white/40 text-[11px] sm:text-xs font-medium tracking-wide">Support</div>
            </div>
            <div class="stat-card rounded-3xl p-5 sm:p-7 text-center transition-all duration-300 hover:scale-[1.03] hover:brightness-110"
                 style="background:#141428;border:1px solid rgba(255,255,255,.05);">
                <div class="font-orbitron font-black text-3xl sm:text-4xl mb-1.5" style="color:#fff;"><span id="stat-produk">10</span></div>
                <div class="text-white/40 text-[11px] sm:text-xs font-medium tracking-wide">Produk</div>
            </div>
            <div class="stat-card rounded-3xl p-5 sm:p-7 text-center transition-all duration-300 hover:scale-[1.03] hover:brightness-110"
                 style="background:#141428;border:1px solid rgba(255,255,255,.05);">
                <div class="font-orbitron font-black text-3xl sm:text-4xl mb-1.5" style="color:#fff;">100<span style="color:#a78bfa;">%</span></div>
                <div class="text-white/40 text-[11px] sm:text-xs font-medium tracking-wide">Terpercaya</div>
            </div>
        </div>
    </div>
</section>

<style>
@keyframes bannerPulse{0%,100%{opacity:.6;transform:scale(1);}50%{opacity:1;transform:scale(1.07);}}
@keyframes slideUpIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
@keyframes dotShimmer{0%{background-position:0% 50%;}100%{background-position:200% 50%;}}

#carousel-track .c-slide{flex:0 0 100%;width:100%;height:100%;position:relative;overflow:hidden;}
#popular-track::-webkit-scrollbar,#testimonialsContainer::-webkit-scrollbar{display:none;}
.glow-first{animation:firstGlowAura 2s ease-in-out infinite;border:3px solid rgba(255,255,255,0.7)!important;}
@keyframes firstGlowAura{0%,100%{box-shadow:0 0 20px rgba(251,191,36,0.6),0 0 40px rgba(139,92,246,0.4),inset 0 0 10px rgba(255,255,255,0.3)}50%{box-shadow:0 0 40px rgba(251,191,36,0.9),0 0 80px rgba(139,92,246,0.7),inset 0 0 20px rgba(255,255,255,0.6)}}
#carousel-track .c-slide>img.c-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;}
#carousel-track .c-slide .c-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(105deg,rgba(0,0,0,.82) 0%,rgba(0,0,0,.45) 45%,rgba(0,0,0,.08) 100%);}
#carousel-track .c-slide .c-body{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;justify-content:center;padding:clamp(14px,4vw,32px) clamp(16px,6vw,48px);max-width:65%;}
#carousel-track .c-slide .c-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;width:fit-content;background:rgba(139,92,246,.22);border:1px solid rgba(139,92,246,.5);color:#c4b5fd;}
#carousel-track .c-slide .c-title{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(14px,3.5vw,30px);color:#fff;line-height:1.15;text-shadow:0 2px 20px rgba(0,0,0,.8);}
#carousel-track .c-slide .c-sub{font-size:clamp(9px,1.6vw,13px);color:rgba(255,255,255,.72);margin-top:5px;line-height:1.4;text-shadow:0 1px 8px rgba(0,0,0,.5);}
#carousel-track .c-slide .c-cta{display:inline-flex;align-items:center;gap:5px;margin-top:10px;padding:7px 16px;border-radius:10px;font-size:10px;font-weight:800;background:linear-gradient(135deg,#7c3aed,#6366f1);color:#fff;border:none;cursor:pointer;transition:all .2s;width:fit-content;box-shadow:0 4px 14px rgba(99,102,241,.4);}
#carousel-track .c-slide .c-cta:hover{transform:translateY(-1px);box-shadow:0 6px 24px rgba(99,102,241,.6);}

.c-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.32);transition:all .38s cubic-bezier(.4,0,.2,1);cursor:pointer;flex-shrink:0;}
.c-dot.active{width:26px;border-radius:4px;background:linear-gradient(90deg,#818cf8,#c4b5fd,#818cf8);background-size:200% 100%;animation:dotShimmer 1.6s linear infinite;box-shadow:0 0 10px rgba(129,140,248,.7);}
.c-dot:hover:not(.active){background:rgba(255,255,255,.55);}

.game-card .card-img-wrap{overflow:hidden;}
.game-card .card-img-wrap img,.game-card .card-img-wrap .card-img-placeholder{transition:transform .35s cubic-bezier(.4,0,.2,1);}
.game-card:hover .card-img-wrap img,.game-card:hover .card-img-wrap .card-img-placeholder{transform:scale(1.1);}
.game-card:active .card-img-wrap img,.game-card:active .card-img-wrap .card-img-placeholder{transform:scale(1.18);transition:transform .15s ease-out;}

@media(max-width:640px){#carousel-track .c-slide .c-body{max-width:82%;}}
</style>

<script>
(function(){
    let slides=[], cur=0, total=1, timer=null;
    const INTERVAL=4200;

    async function initCarousel(){
        try{ const r=await fetch('/api/banners'); slides=await r.json(); }catch{ slides=[]; }

        const track=document.getElementById('carousel-track');
        const dotsEl=document.getElementById('carousel-dots');
        const prevBtn=document.getElementById('carousel-prev');
        const nextBtn=document.getElementById('carousel-next');

        if(!slides.length){ total=1; return; }

        document.getElementById('c-slide-default')?.remove();

        track.innerHTML=slides.map((s,i)=>{
            const hl=s.link&&s.link!=='/';
            return `<div class="c-slide"${hl?` onclick="window.location='${s.link}'" style="cursor:pointer"`:''}>
                <img class="c-img" src="${s.imageUrl}" alt="${s.title||''}" loading="${i===0?'eager':'lazy'}"
                     onerror="this.style.display='none';this.closest('.c-slide').style.background='linear-gradient(135deg,#12082a,#07071a)'">
                <div class="c-overlay"></div>
                <div class="c-body" style="animation:slideUpIn .45s ease-out both;">
                    ${s.title||s.subtitle?`<div class="c-badge"><iconify-icon icon="mdi:lightning-bolt" style="font-size:8px;"></iconify-icon> PROMO</div>`:''}
                    ${s.title?`<div class="c-title">${s.title}</div>`:''}
                    ${s.subtitle?`<div class="c-sub">${s.subtitle}</div>`:''}
                    ${hl?`<div class="c-cta"><iconify-icon icon="mdi:arrow-right" style="font-size:11px;"></iconify-icon> Lihat Detail</div>`:''}
                </div>
            </div>`;
        }).join('');

        total=slides.length;
        dotsEl.innerHTML=slides.map((_,i)=>
            `<div class="c-dot${i===0?' active':''}" onclick="goSlide(${i})"></div>`
        ).join('');

        if(total>1){
            prevBtn?.classList.replace('hidden','flex');
            nextBtn?.classList.replace('hidden','flex');
            startAuto();
            addSwipe();
        }
        goSlide(0);
    }

    window.goSlide=function(idx){
        if(total<=1)return;
        cur=((idx%total)+total)%total;
        document.getElementById('carousel-track').style.transform=`translateX(-${cur*100}%)`;
        document.querySelectorAll('.c-dot').forEach((d,i)=>d.classList.toggle('active',i===cur));
    };
    window.carouselMove=function(dir){ goSlide(cur+dir); resetAuto(); };
    function startAuto(){ clearInterval(timer); timer=setInterval(()=>goSlide(cur+1),INTERVAL); }
    function resetAuto(){ clearInterval(timer); startAuto(); }
    function addSwipe(){
        const w=document.getElementById('carousel-wrap');
        w.addEventListener('mouseenter',()=>clearInterval(timer));
        w.addEventListener('mouseleave',()=>startAuto());
        w.addEventListener('touchstart',e=>{ clearInterval(timer); w.dataset.tx=e.touches[0].clientX; },{passive:true});
        w.addEventListener('touchend',e=>{
            const dx=e.changedTouches[0].clientX-(parseFloat(w.dataset.tx)||0);
            if(Math.abs(dx)>38)goSlide(cur+(dx<0?1:-1));
            startAuto();
        },{passive:true});
    }

    document.addEventListener('DOMContentLoaded',initCarousel);
})();
</script>

