                            <span class="text-white/30">Terjual <span class="text-white/50 font-bold"><%= soldLabel %></span></span>
                        </div>
                        <% if (!isOut) { %>
                            <a href="/buy/<%= product.id %>"
                               class="btn-primary w-full py-1.5 sm:py-2.5 rounded-lg sm:rounded-xl text-[9px] sm:text-xs font-bold text-white flex items-center justify-center gap-1">
                                <iconify-icon icon="solar:cart-large-2-bold" class="text-[9px] sm:text-sm"></iconify-icon>Beli
                            </a>
                        <% } else { %>
                            <button disabled class="w-full py-1.5 sm:py-2.5 rounded-lg sm:rounded-xl text-[9px] sm:text-xs font-bold cursor-not-allowed flex items-center justify-center gap-1"
                                style="background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.06);">
                                <iconify-icon icon="solar:close-circle-bold" class="text-[9px] sm:text-sm"></iconify-icon>Habis
                            </button>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <% if (products.length === 0) { %>
        <div class="col-span-3 text-center py-16">
            <iconify-icon icon="solar:box-minimalistic-bold" class="text-3xl text-white/10 mb-3 block mx-auto"></iconify-icon>
            <p class="text-white/15 text-xs">Belum ada produk tersedia</p>
        </div>
        <% } %>
    </div>
