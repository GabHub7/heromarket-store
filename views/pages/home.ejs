<script>
    function toggleMobile() {
        const menu = document.getElementById('mobile-menu');
        const icon = document.getElementById('menu-icon');
        menu.classList.toggle('hidden');
        if (icon) {
            icon.setAttribute('icon', menu.classList.contains('hidden') ? 'mdi:menu' : 'mdi:close');
        }
    }

    function closeMobile() {
        document.getElementById('mobile-menu').classList.add('hidden');
        const icon = document.getElementById('menu-icon');
        if (icon) icon.setAttribute('icon', 'mdi:menu');
    }

    function filterProducts(category) {
        const cards = document.querySelectorAll('[data-category]');
        const buttons = document.querySelectorAll('.prod-filter,.cat-btn');

        buttons.forEach(btn => {
            const key = btn.dataset.pf || btn.dataset.cat;
            const isActive = key === category;
            btn.classList.toggle('active', isActive);
            if (isActive) {
                btn.classList.add('bg-violet-600','text-white');
                btn.classList.remove('bg-white/5','text-white/40');
                btn.style.background = '';
                btn.style.color = '';
            } else {
                btn.classList.remove('bg-violet-600','text-white');
                btn.classList.add('bg-white/5','text-white/40');
                btn.style.background = '';
                btn.style.color = '';
            }
        });

        cards.forEach(card => {
            card.style.display = (category === 'all' || card.dataset.category === category) ? '' : 'none';
        });
    }

    async function loadTestimonials() {
        const container = document.getElementById('testimonialsContainer');
        try {
            const response = await fetch('/api/testimonials?verified=true');
            const testimonials = await response.json();

            if (testimonials.length === 0) {
                container.innerHTML = `<div class="flex-shrink-0 w-full text-center py-10">
                    <iconify-icon icon="mdi:comment-outline" class="text-4xl text-zinc-700 block mx-auto mb-2"></iconify-icon>
                    <p class="text-xs text-zinc-600">Belum ada ulasan. Jadilah yang pertama!</p>
                </div>`;
                return;
            }

            // Statistik rating
            const total = testimonials.length;
            const avg = (testimonials.reduce((s,t) => s + (t.rating||0), 0) / total).toFixed(1);
            const avgEl = document.getElementById('avg-rating-home');
            const cntEl = document.getElementById('total-reviews-home');
            if (avgEl) avgEl.textContent = avg;
            if (cntEl) cntEl.textContent = `(${total})`;

            // Rating bars
            const barsEl = document.getElementById('rating-bars-home');
            if (barsEl) {
                barsEl.classList.remove('hidden');
                for (let s=1; s<=5; s++) {
                    const cnt = testimonials.filter(t => t.rating === s).length;
                    const pct = total ? (cnt/total*100).toFixed(0) : 0;
                    const bar = document.getElementById(`hbar-${s}`);
                    const lbl = document.getElementById(`hcount-${s}`);
                    if (bar) setTimeout(() => bar.style.width = pct + '%', 150);
                    if (lbl) lbl.textContent = cnt || '';
                }
            }

            const avatarColors = ['#6366f1,#8b5cf6','#7c3aed,#a855f7','#0ea5e9,#6366f1','#10b981,#059669','#f59e0b,#d97706','#ec4899,#db2777'];

            container.innerHTML = testimonials.map((t, idx) => {
                const name = t.name || t.username || 'Pembeli';
                const initials = name.charAt(0).toUpperCase();
                const grad = avatarColors[idx % avatarColors.length];
                const avatarHtml = t.photo
                    ? `<img src="${t.photo}" class="w-9 h-9 rounded-xl object-cover flex-shrink-0" style="border:2px solid rgba(139,92,246,.3);">`
                    : `<div class="w-9 h-9 rounded-xl flex items-center justify-center text-white text-xs font-black flex-shrink-0" style="background:linear-gradient(135deg,${grad});">${initials}</div>`;
                const starsHtml = Array.from({length:5}, (_,i) =>
                    `<iconify-icon icon="${i < t.rating ? 'mdi:star' : 'mdi:star-outline'}" style="font-size:11px;color:${i < t.rating ? '#fbbf24' : '#3f3f46'};"></iconify-icon>`
                ).join('');
                const date = new Date(t.date).toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'});
                const productLabel = t.productName || t.product || '';
                return `<div class="glass rounded-xl p-4 flex-shrink-0 hover:border-violet-500/20 transition-colors fade-in-up"
                    style="min-width:265px;width:265px;scroll-snap-align:start;animation-delay:${idx*60}ms">
                    <div class="flex items-start justify-between gap-2 mb-2.5">
                        <div class="flex items-center gap-2.5">
                            ${avatarHtml}
                            <div>
                                <div class="text-[12px] font-bold text-white leading-tight">${name}</div>
                                <div class="flex items-center gap-0.5 mt-0.5">
                                    ${starsHtml}
                                    ${t.verified ? '<iconify-icon icon="mdi:check-decagram" style="font-size:10px;color:#34d399;margin-left:3px;"></iconify-icon>' : ''}
                                </div>
                            </div>
                        </div>
                        <span class="text-[9px] text-zinc-600 flex-shrink-0 mt-0.5">${date}</span>
                    </div>
                    <p class="text-[11px] text-zinc-400 leading-relaxed mb-2">"${t.text}"</p>
                    ${productLabel ? `<div class="flex items-center gap-1 text-[10px] text-indigo-400">
                        <iconify-icon icon="mdi:gamepad-variant-outline" style="font-size:10px;"></iconify-icon> ${productLabel}
                    </div>` : ''}
                </div>`;
            }).join('');

            // Re-bind drag after cards rendered
            enableDragScroll(container);

            // Dots indicator
            const dotsEl = document.getElementById('testi-dots');
            if (dotsEl && testimonials.length > 1) {
                const pageCount = Math.ceil(testimonials.length / 1);
                const visibleCount = Math.min(pageCount, 8);
                dotsEl.innerHTML = Array.from({length: visibleCount}, (_, i) =>
                    `<div class="testi-dot rounded-full transition-all duration-300" data-page="${i}"
                        style="height:5px;width:${i===0?'18px':'5px'};background:${i===0?'rgba(139,92,246,.9)':'rgba(139,92,246,.25)'};"></div>`
                ).join('');
                container.addEventListener('scroll', () => {
                    const progress = container.scrollLeft / (container.scrollWidth - container.offsetWidth);
                    const activePage = Math.round(progress * (visibleCount - 1));
                    dotsEl.querySelectorAll('.testi-dot').forEach((d, i) => {
                        d.style.background = i === activePage ? 'rgba(139,92,246,.9)' : 'rgba(139,92,246,.25)';
                        d.style.width = i === activePage ? '18px' : '5px';
                    });
                }, {passive: true});
            }
        } catch (error) {
            container.innerHTML = '<div class="flex-shrink-0 w-full text-center py-8 text-xs text-zinc-600">Gagal memuat ulasan</div>';
        }
    }

    function loadAllTestimonials() { /* no-op, semua tampil di carousel */ }

    async function loadLeaderboardHome() {
        const list = document.getElementById('leaderboard-home-list');
        const top3El = document.getElementById('leaderboard-top3');
        if (!list) return;
        try {
            const res = await fetch('/api/leaderboard?limit=8');
            const data = await res.json();
            const entries = Array.isArray(data) ? data : (data.entries || data.data || []);
            if (!entries.length) {
                list.innerHTML = '<div class="text-center py-6 text-xs text-white/20">Belum ada data leaderboard</div>';
                if (top3El) top3El.innerHTML = '';
                return;
            }

            const avatarGrads = ['from-violet-400 to-purple-500','from-gray-300 to-gray-400','from-orange-400 to-orange-600','from-violet-400 to-purple-500','from-blue-400 to-cyan-500','from-green-400 to-emerald-500','from-red-400 to-rose-500','from-pink-400 to-fuchsia-500'];

            // TOP 3 PODIUM
            if (top3El && entries.length >= 3) {
                const top3 = entries.slice(0, 3);
                // order: 2nd, 1st, 3rd
                const ordered = [top3[1], top3[0], top3[2]];
                const heights = ['h-20 w-20 sm:h-24 sm:w-24','h-24 w-24 sm:h-28 sm:w-28','h-16 w-16 sm:h-20 sm:w-20'];
                const margins = ['',''-mt-4 sm:-mt-6'',''];
                const rankBgs = ['bg-gray-400/20 text-gray-300 border-gray-400/30','bg-yellow-500/20 text-yellow-300 border-yellow-500/30','bg-orange-500/20 text-orange-300 border-orange-500/30'];
                top3El.innerHTML = ordered.map((u, i) => {
                    if (!u) return '';
                    const origIdx = [1,0,2][i];
                    const name = u.username || u.name || 'User';
                    const spent = u.totalSpent || u.total_spent || 0;
                    const initials = name.substring(0,2).toUpperCase();
                    const isFirst = origIdx === 0;
                    const sz = heights[i];
                    const mg = origIdx===0 ? '-mt-4 sm:-mt-6' : '';
                    return `<div class="flex flex-col items-center ${mg} relative z-10">
                        <div class="relative flex flex-col items-center mb-2">
                            ${isFirst ? '<div class="absolute -top-5 sm:-top-6 text-2xl sm:text-3xl" style="filter:drop-shadow(0 0 8px #fbbf24)"><iconify-icon icon="solar:crown-bold" style="color:gold"></iconify-icon></div>' : ''}
                            <div class="${sz} ${isFirst?'glow-first':''} rounded-full bg-gradient-to-br ${avatarGrads[origIdx]} flex items-center justify-center font-bold ${isFirst?'text-black':'text-white'} shadow-lg relative z-10 text-sm sm:text-base">${initials}</div>
                        </div>
                        <span class="text-white font-bold text-[10px] sm:text-sm mt-1 text-center max-w-[80px] truncate">${name}</span>
                        <span class="text-white/40 text-[9px] sm:text-xs font-medium">Rp ${Number(spent).toLocaleString('id-ID')}</span>
                        <span class="mt-1.5 text-[9px] font-bold px-2.5 py-0.5 rounded-md ${rankBgs[origIdx]} border">#${origIdx+1}</span>
                    </div>`;
                }).join('');
            }

            // REST LIST (rank 4+)
            const rest = entries.slice(3);
            if (!rest.length) { list.innerHTML = ''; return; }
            list.innerHTML = rest.map((u, i) => {
                const name = u.username || u.name || 'User';
                const spent = u.totalSpent || u.total_spent || 0;
                const txCount = u.totalTransactions || 0;
                const initials = name.substring(0,2).toUpperCase();
                return `<div class="flex items-center gap-3 p-2 sm:p-2.5 rounded-lg hover:bg-white/[0.02] transition-colors">
                    <span class="text-white/30 font-bold w-6 text-center text-xs">${i+4}</span>
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br ${avatarGrads[(i+3)%avatarGrads.length]} flex items-center justify-center text-[9px] font-bold text-white">${initials}</div>
                    <div class="flex-1 min-w-0"><span class="text-white text-xs sm:text-sm font-medium block truncate">${name}</span></div>
                    <div class="text-right">
                        <div class="text-white/40 text-[9px] sm:text-xs font-medium whitespace-nowrap">${txCount}x beli</div>
                        <div class="text-white/25 text-[8px]">Rp ${Number(spent).toLocaleString('id-ID')}</div>
                    </div>
                </div>`;
            }).join('');
        } catch(e) {
            if (list) list.innerHTML = '<div class="text-center py-6 text-xs text-white/20">Gagal memuat data</div>';
        }
    }

    async function loadPopularProducts() {
        const track = document.getElementById('popular-track');
        if (!track) return;
        try {
            // Ambil produk populer dari server (admin bisa atur urutan via popularProductIds di settings)
            const popularProds = <%- JSON.stringify(popularProducts) %>;
            if (!popularProds.length) { track.innerHTML = ''; return; }
            const badgeLabels = ['BEST','HOT','TOP','NEW','SALE'];
            const badgeCls = ['bg-red-500/80','bg-yellow-500/80 text-black','bg-blue-500/80','bg-emerald-500/80','bg-fuchsia-500/80'];
            track.innerHTML = popularProds.map((p, idx) => {
                const isOut = !(p.keys && p.keys.length);
                const price = p.items && p.items.length > 0 ? p.items[0].p : null;
                const hasPlatform = p.platforms && p.platforms.length > 0 ? p.platforms[0].toUpperCase() : '';
                const badge = p.badge || badgeLabels[idx % 5];
                const bCls = p.badgeColor || badgeCls[idx % 5];
                const soldFmt = (p.sold||0) >= 1000 ? ((p.sold||0)/1000).toFixed(1).replace('.0','')+'K' : String(p.sold||0);
                return `<div class="popular-card glass rounded-xl overflow-hidden border border-white/[0.04] cursor-pointer" onclick="location.href='/buy/${p.id}'"
                    style="min-width:200px;max-width:200px;scroll-snap-align:start;flex-shrink:0;">
                    <div class="relative h-28 sm:h-36 overflow-hidden">
                        ${badge ? `<span class="badge-tag ${bCls} absolute top-1.5 left-1.5 z-10">${badge}</span>` : ''}
                        ${p.image ? `<img src="${p.image}" alt="${p.name}" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'">` : `<div class="w-full h-full flex items-center justify-center" style="background:rgba(99,102,241,.06);"><iconify-icon icon="solar:gamepad-bold" style="font-size:32px;color:rgba(139,92,246,.4);"></iconify-icon></div>`}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent pointer-events-none"></div>
                        ${hasPlatform ? `<div class="absolute top-1.5 right-1.5 z-10"><span class="platform-label">${hasPlatform}</span></div>` : ''}
                    </div>
                    <div class="p-2 sm:p-3">
                        <h3 class="font-display font-bold text-[10px] sm:text-sm truncate mb-1.5">${p.name}</h3>
                        <div class="flex justify-between items-center text-[8px] sm:text-[10px] mb-2">
                            <span class="text-white/30">Terjual <span class="text-white/50 font-bold">${soldFmt}</span></span>
                            ${price ? `<span class="font-bold text-violet-400 text-[10px] sm:text-xs">Rp ${Number(price).toLocaleString('id-ID')}</span>` : ''}
                        </div>
                        <button class="btn-primary w-full py-1.5 sm:py-2.5 rounded-lg sm:rounded-xl text-[9px] sm:text-xs font-bold text-white flex items-center justify-center gap-1 ${isOut?'opacity-40 cursor-not-allowed':''}"
                            ${isOut ? 'disabled' : ''}>
                            <iconify-icon icon="${isOut ? 'solar:close-circle-bold' : 'solar:cart-large-2-bold'}" class="text-[9px] sm:text-sm"></iconify-icon>${isOut ? 'Habis' : 'Beli'}
                        </button>
                    </div>
                </div>`;
            }).join('');
        } catch(e) {
            track.innerHTML = '';
        }
    }

    // ── Drag-to-scroll: mouse drag support for horizontal scroll containers ──
    function enableDragScroll(el) {
        if (!el) return;
        let isDown = false, startX, scrollLeft;
        el.addEventListener('mousedown', e => {
            isDown = true;
            el.style.cursor = 'grabbing';
            startX = e.pageX - el.offsetLeft;
            scrollLeft = el.scrollLeft;
            e.preventDefault();
        });
        el.addEventListener('mouseleave', () => { isDown = false; el.style.cursor = ''; });
        el.addEventListener('mouseup', () => { isDown = false; el.style.cursor = ''; });
        el.addEventListener('mousemove', e => {
            if (!isDown) return;
            const x = e.pageX - el.offsetLeft;
            el.scrollLeft = scrollLeft - (x - startX) * 1.2;
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadTestimonials();
        loadFooterStats();
        loadLeaderboardHome();
        loadPopularProducts();
        initCatBtn();
        // Enable mouse drag on both scroll containers
        enableDragScroll(document.getElementById('popular-track'));
        enableDragScroll(document.getElementById('testimonialsContainer'));
    });

    function initCatBtn() {
        const activeBtn = document.querySelector('.cat-btn.active');
        if (activeBtn) {
            activeBtn.style.background = 'rgba(99,102,241,.15)';
            activeBtn.style.color = '#818cf8';
            activeBtn.style.borderColor = 'rgba(99,102,241,.4)';
            activeBtn.style.boxShadow = '0 0 12px rgba(99,102,241,.25)';
        }
    }

    async function loadFooterStats() {
        try {
            const res = await fetch('/api/stats');
            const s = await res.json();
            animateCount('footer-stat-sold', s.totalSold, s.totalSold > 0 ? '+' : '');
            animateCount('footer-stat-users', s.totalUsers, '+');
            animateFloat('footer-stat-rating', s.avgRating);
            animateCount('footer-stat-products', s.totalActiveProducts, '');
        } catch(e) {
            ['footer-stat-sold','footer-stat-users','footer-stat-rating','footer-stat-products']
                .forEach(id => { const el = document.getElementById(id); if(el) el.textContent = '—'; });
        }
    }

    function animateFloat(id, target) {
        const el = document.getElementById(id);
        if (!el) return;
        let current = 0;
        const step = target / 40;
        const interval = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = current.toFixed(1);
            if (current >= target) clearInterval(interval);
        }, 40);
    }

    function animateCount(id, target, suffix = '') {
        const el = document.getElementById(id);
        if (!el) return;
        let current = 0;
        const step = Math.ceil(target / 40);
        const interval = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = current.toLocaleString('id-ID') + suffix;
            if (current >= target) clearInterval(interval);
        }, 40);
    }
</script>
