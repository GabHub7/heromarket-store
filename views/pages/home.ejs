<!-- FLOATING BUTTONS -->
<div class="hidden md:flex fixed bottom-6 right-6 z-40 flex-col gap-3">
    <% if (settings.contact?.whatsapp) { %>
    <a href="https://wa.me/<%= settings.contact.whatsapp %>" target="_blank"
       class="w-12 h-12 rounded-full flex items-center justify-center transition-all hover:scale-110"
       style="background:#22c55e;box-shadow:0 4px 20px rgba(34,197,94,.4);">
        <iconify-icon icon="mdi:whatsapp" class="text-white text-xl"></iconify-icon>
    </a>
    <% } %>
    <% if (settings.contact?.telegram) { %>
    <a href="https://t.me/<%= settings.contact.telegram %>" target="_blank"
       class="w-12 h-12 rounded-full flex items-center justify-center transition-all hover:scale-110"
       style="background:#3b82f6;box-shadow:0 4px 20px rgba(59,130,246,.4);">
        <iconify-icon icon="mdi:telegram" class="text-white text-xl"></iconify-icon>
