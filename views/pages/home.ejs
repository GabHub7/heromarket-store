            </h2>
            <p class="text-white/25 text-[10px] sm:text-xs">Filter berdasarkan game</p>
        </div>

        <% if (categories && categories.length > 0) { %>
        <div class="filter-scroll flex gap-2 mb-6 sm:mb-8 overflow-x-auto pb-1" style="-ms-overflow-style:none;scrollbar-width:none;">
            <div class="filter-sticky-left">
                <button onclick="filterProducts('all')" class="prod-filter px-4 sm:px-5 py-2 sm:py-2.5 rounded-xl text-[11px] sm:text-xs font-semibold transition-all whitespace-nowrap bg-violet-600 text-white" data-pf="all">Semua</button>
            </div>
            <% categories.forEach(cat => { %>
                <button onclick="filterProducts('<%= cat %>')" class="prod-filter flex-shrink-0 px-4 sm:px-5 py-2 sm:py-2.5 rounded-xl text-[11px] sm:text-xs font-semibold transition-all whitespace-nowrap bg-white/5 text-white/40 hover:text-white hover:bg-white/8" data-pf="<%= cat %>">
                    <%= categoryLabels[cat] || cat.toUpperCase() %>
                </button>
            <% }) %>
        </div>
        <% } %>

        <div id="product-grid" class="grid grid-cols-3 gap-2 sm:gap-5">
            <% products.forEach((product, pIdx) => {
                const stock = product.keys ? product.keys.length : 0;
                const isOut = stock === 0;
                const isLow = stock > 0 && stock <= 5;
                const hasAndroid = product.platforms && product.platforms.includes('android');
                const hasIos = product.platforms && product.platforms.includes('ios');
                const fakeStockSeeds = [48,24,67,31,55,19,42,73,28,61,35,44,52,38,29,63,47,21,58,36];
                const fakeSoldSeeds  = [3200,2800,1900,4100,2100,3700,1500,2400,3300,1700,2600,4500,1200,2900,3800,1600,2200,3500,1100,2700];
                const displayStock = stock > 0 ? stock : fakeStockSeeds[pIdx % fakeStockSeeds.length];
                const displaySold  = (product.sold && product.sold > 0) ? product.sold : fakeSoldSeeds[pIdx % fakeSoldSeeds.length];
                const soldLabel    = displaySold >= 1000 ? (displaySold/1000).toFixed(1).replace('.0','') + 'K' : String(displaySold);
                const badgeLabels = ['BEST','HOT','TOP','NEW','SALE'];
                const badgeColors = ['bg-red-500/80','bg-yellow-500/80 text-black','bg-blue-500/80','bg-emerald-500/80','bg-fuchsia-500/80'];
                const autoBadge = badgeLabels[pIdx % 5];
                const autoBadgeColor = badgeColors[pIdx % 5];
                const productBadge = product.badge || autoBadge;
                const productBadgeColor = product.badgeColor || autoBadgeColor;
            %>
                <div class="product-card glass rounded-xl sm:rounded-2xl overflow-hidden border border-white/[0.04]" data-category="<%= product.category %>">
                    <div class="relative overflow-hidden" style="height:96px;" class="sm:h-40">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover" loading="lazy"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <div class="absolute inset-0 items-center justify-center hidden" style="background:rgba(99,102,241,.06);">
                                <iconify-icon icon="solar:gamepad-bold" class="text-2xl text-violet-400/40"></iconify-icon>
                            </div>
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center" style="background:rgba(99,102,241,.06);">
                                <iconify-icon icon="solar:gamepad-bold" class="text-2xl text-violet-400/40"></iconify-icon>
                            </div>
                        <% } %>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent pointer-events-none"></div>
                        <% if (productBadge) { %>
                            <span class="badge-tag <%= productBadgeColor %> absolute top-1.5 left-1.5 z-10"><%= productBadge %></span>
                        <% } %>
                        <div class="absolute top-1.5 right-1.5 z-10">
                            <% if (hasAndroid) { %>
                                <span class="platform-label">ANDROID</span>
                            <% } else if (hasIos) { %>
                                <span class="platform-label">iOS</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="p-2 sm:p-3">
                        <h3 class="font-display font-bold text-[9px] sm:text-sm truncate mb-1.5"><%= product.name %></h3>
                        <div class="flex justify-between items-center text-[7px] sm:text-[10px] mb-2">
