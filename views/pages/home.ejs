                <h4 class="text-[10px] font-bold uppercase tracking-[0.15em] text-white/50 mb-4">Pembayaran</h4>
                <div class="grid grid-cols-3 gap-1.5">
                    <div class="px-2 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-center text-[9px] text-white/30 font-semibold">GoPay</div>
                    <div class="px-2 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-center text-[9px] text-white/30 font-semibold">OVO</div>
                    <div class="px-2 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-center text-[9px] text-white/30 font-semibold">DANA</div>
                    <div class="px-2 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-center text-[9px] text-white/30 font-semibold">BCA</div>
                    <div class="px-2 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-center text-[9px] text-white/30 font-semibold">QRIS</div>
                    <div class="px-2 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-center text-[9px] text-white/30 font-semibold">ShopeePay</div>
                </div>
            </div>
        </div>

        <div class="border-t border-white/[0.05] pt-5 flex flex-col sm:flex-row items-center justify-between gap-3">
            <p class="text-white/15 text-[10px] text-center sm:text-left">&copy; 2026 <%= settings.siteName || 'Hero Market' %>. All rights reserved.</p>
            <div class="flex items-center gap-2 text-white/15 text-[10px]">
                <span class="w-1.5 h-1.5 rounded-full" style="background:#22c55e;box-shadow:0 0 6px #22c55e;"></span>
                Online
            </div>
        </div>
